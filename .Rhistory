library(KEGGREST)
conv <- keggConv("ncbi-geneid", "eco")
conv_df <- data.frame(
kegg = names(conv),
entrez = conv,
stringsAsFactors = FALSE
)
conv_df$kegg <- sub("eco:", "", conv_df$kegg)
conv_df$entrez <- sub("ncbi-geneid:", "", conv_df$entrez)
mapped <- conv_df[
conv_df$kegg %in% gene_list,
]
head(mapped)
nrow(mapped)
library(clusterProfiler)
kk <- enrichKEGG(
gene = mapped$entrez,
organism = "eco",
keyType = "ncbi-geneid",
pvalueCutoff = 0.05
)
head(kk)
summary(kk)
library(enrichplot)
dotplot(kk)
barplot(kk)
kk@result
